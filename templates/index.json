        "collection_1",
        "collection_2",
        "collection_3"
      ],
      "settings": {
        "title": "Shop by Category",
        "border_color": "#E7B8B7"
      }
    },
    "featured_product": {
      "type": "featured-product",
      "settings": {
        "color_scheme": "scheme-1",
