<div class="manual-products section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="title inline-richtext {{ section.settings.heading_size }}" style="text-align: center;">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="manual-products__grid grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop" style="margin-top: 30px;">
      {%- for block in section.blocks -%}
        <div class="grid__item">
          {%- if block.settings.product != blank -%}
            {% render 'card-product',
              card_product: block.settings.product,
              media_aspect_ratio: 'adapt',
              show_secondary_image: true,
              show_vendor: false,
              show_rating: false
            %}
          {%- else -%}
            <div class="card-wrapper" style="border: 1px dashed #ccc; padding: 20px; text-align: center;">
              Select a Product
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Manual Product Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Selected Products",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "Number of columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "product_block",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Manual Product Grid",
      "blocks": [
        {
          "type": "product_block"
        },
        {
          "type": "product_block"
        },
        {
          "type": "product_block"
        },
        {
          "type": "product_block"
        }
      ]
    }
  ]
}
{% endschema %}
