<div class="achievements section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="title inline-richtext {{ section.settings.heading_size }}" style="text-align: center;">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="achievements__grid" style="display: flex; gap: 30px; flex-wrap: wrap; justify-content: center; margin-top: 30px; text-align: center;">
      {%- for block in section.blocks -%}
        <div class="achievement__item" style="flex: 1 1 200px; padding: 20px;">
          {%- if block.settings.image != blank -%}
            <div style="margin-bottom: 15px;">
              <img src="{{ block.settings.image | image_url: width: 100 }}" alt="{{ block.settings.title }}" style="max-width: 80px; height: auto;">
            </div>
          {%- endif -%}
          <h3 class="h4" style="color: {{ section.settings.accent_color }};">{{ block.settings.title }}</h3>
          <div class="achievement__text">
            {{ block.settings.text }}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Achievements",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Our Achievements",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#E7B8B7"
    }
  ],
  "blocks": [
    {
      "type": "achievement",
      "name": "Achievement",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon/Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Award Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Description of the achievement or recognition.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Achievements",
      "blocks": [
        {
          "type": "achievement"
        },
        {
          "type": "achievement"
        },
        {
          "type": "achievement"
        }
      ]
    }
  ]
}
{% endschema %}
