<div class="testimonials section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="title inline-richtext {{ section.settings.heading_size }}" style="text-align: center;">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="testimonials__grid" style="display: flex; gap: 30px; flex-wrap: wrap; justify-content: center; margin-top: 30px;">
      {%- for block in section.blocks -%}
        <div class="testimonial__item" style="flex: 1 1 300px; padding: 20px; background: #fff; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); border-top: 4px solid {{ section.settings.accent_color }};">
          <div class="testimonial__stars" style="color: {{ section.settings.accent_color }}; margin-bottom: 15px;">
            ★★★★★
          </div>
          <div class="testimonial__text" style="font-style: italic; margin-bottom: 15px;">
            "{{ block.settings.text }}"
          </div>
          <div class="testimonial__author" style="font-weight: bold;">
            - {{ block.settings.author }}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "What Our Customers Say",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#E7B8B7"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "This product changed my life! Highly recommended."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Jane Doe"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        }
      ]
    }
  ]
}
{% endschema %}
